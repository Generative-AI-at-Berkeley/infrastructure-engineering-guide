generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id        Int      @id @default(autoincrement())
  name      String
  classYear Int      @map("class_year")
  email     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("students")
}
